{
  "inputs": {
    "designRequirements": {
      "efficiency": 0.88,
      "inputType": "dc",
      "inputVoltage": { "minimum": 36.0, "nominal": 48.0, "maximum": 60.0 },
      "switchingFrequency": { "nominal": 100000 },
      "isolationVoltage": 1500,
      "outputs": [
        { "name": "12V", "voltage": { "nominal": 12.0, "minimum": 11.76, "maximum": 12.24 }, "regulation": "voltage" }
      ]
    },
    "operatingPoints": [
      { "name": "full_load_Vin_nom", "inputVoltage": 48.0, "ambientTemperature": 25.0,
        "outputs": [ { "name": "12V", "power": 24.0 } ] },
      { "name": "full_load_Vin_min", "inputVoltage": 36.0, "ambientTemperature": 25.0,
        "outputs": [ { "name": "12V", "power": 24.0 } ] },
      { "name": "full_load_Vin_max", "inputVoltage": 60.0, "ambientTemperature": 25.0,
        "outputs": [ { "name": "12V", "power": 24.0 } ] }
    ]
  },

  "topology": {
    "stages": [
      {
        "name": "inverter",
        "role": "inverter",
        "inputPort":  { "type": "dcBus", "wire": "Vin" },
        "outputPorts": [ { "type": "hfAc", "wire": "sw_node" } ],
        "circuit": {
          "components": [
            { "name": "Q1", "data": "TAS/data/mosfets.ndjson?partNumber=C3M0032120K" },
            { "name": "C_in", "data": "TAS/data/capacitors.ndjson?partNumber=B32774" }
          ],
          "connections": [
            { "name": "drain", "kind": "wire",
              "endpoints": [ { "component": "Q1", "pin": "D" }, { "component": "C_in", "pin": "1" } ] }
          ]
        }
      },

      {
        "name": "transformer",
        "role": "isolation",
        "inputPort":  { "type": "hfAc", "wire": "sw_node" },
        "outputPorts": [ { "type": "hfAc", "wire": "sec", "name": "12V" } ],
        "circuit": {
          "components": [
            { "name": "T1", "data": "TAS/data/transformers.ndjson?partNumber=FLY-48-12-24W" }
          ],
          "connections": [
            { "name": "K_T1", "kind": "coupling", "couplingCoefficient": 0.995,
              "endpoints": [ { "component": "T1" }, { "component": "T1" } ] }
          ]
        }
      },

      {
        "name": "rectifier",
        "role": "outputRectifier",
        "inputPort":  { "type": "hfAc", "wire": "sec" },
        "outputPorts": [ { "type": "pulsatingDc", "wire": "rect_out" } ],
        "circuit": {
          "components": [
            { "name": "D1", "data": "TAS/data/diodes.ndjson?partNumber=STPS20H100C" }
          ],
          "connections": [
            { "name": "anode", "kind": "wire",
              "endpoints": [ { "component": "D1", "pin": "A" }, { "component": "D1", "pin": "K" } ] }
          ]
        }
      },

      {
        "name": "filter",
        "role": "outputFilter",
        "inputPort":  { "type": "pulsatingDc", "wire": "rect_out" },
        "outputPorts": [ { "type": "dcOutput", "wire": "Vout" } ],
        "circuit": {
          "components": [
            { "name": "C_out", "data": "TAS/data/capacitors.ndjson?partNumber=EEE-FK1V471P" }
          ],
          "connections": [
            { "name": "cap_top", "kind": "wire",
              "endpoints": [ { "component": "C_out", "pin": "1" }, { "component": "C_out", "pin": "2" } ] }
          ]
        }
      },

      {
        "name": "controller",
        "role": "control",
        "circuit": {
          "components": [
            { "name": "U1", "data": "TAS/data/controllers.ndjson?partNumber=UCC28C44" }
          ],
          "connections": []
        },
        "senses": [
          { "wire": "Vout", "signal": "voltage" }
        ],
        "drives": [
          { "component": "Q1", "signal": "gate" }
        ]
      }
    ],

    "interStageCircuit": [
      { "name": "Vin",  "kind": "externalPort", "direction": "input",
        "endpoints": [ { "component": "C_in", "pin": "2" }, { "component": "Q1", "pin": "S" } ] },
      { "name": "Vout", "kind": "externalPort", "direction": "output",
        "endpoints": [ { "component": "C_out", "pin": "1" }, { "component": "C_out", "pin": "2" } ] },
      { "name": "sw_node", "kind": "wire",
        "endpoints": [ { "component": "Q1", "pin": "D" }, { "component": "T1", "pin": "P1" } ] },
      { "name": "sec", "kind": "wire",
        "endpoints": [ { "component": "T1", "pin": "S1" }, { "component": "D1", "pin": "A" } ] },
      { "name": "rect_out", "kind": "wire",
        "endpoints": [ { "component": "D1", "pin": "K" }, { "component": "C_out", "pin": "1" } ] }
    ]
  }
}
