{
  "inputs": {
    "designRequirements": {
      "efficiency": 0.88,
      "inputType": "dc",
      "inputVoltage": { "minimum": 36.0, "nominal": 48.0, "maximum": 60.0 },
      "switchingFrequency": { "nominal": 100000 },
      "isolationVoltage": 1500,
      "outputs": [
        { "name": "12V", "voltage": { "nominal": 12.0, "minimum": 11.76, "maximum": 12.24 }, "regulation": "voltage" }
      ]
    },
    "operatingPoints": [
      { "name": "full_load_Vin_nom", "inputVoltage": 48.0, "ambientTemperature": 25.0,
        "outputs": [ { "name": "12V", "power": 24.0 } ] },
      { "name": "full_load_Vin_min", "inputVoltage": 36.0, "ambientTemperature": 25.0,
        "outputs": [ { "name": "12V", "power": 24.0 } ] },
      { "name": "full_load_Vin_max", "inputVoltage": 60.0, "ambientTemperature": 25.0,
        "outputs": [ { "name": "12V", "power": 24.0 } ] }
    ]
  },

  "topology": {
    "stages": [
      {
        "name": "inverter",
        "role": "inverter",
        "circuit": {
          "name": "primary-switch",
          "ports": [ { "name": "dc+" }, { "name": "dc-" }, { "name": "sw" }, { "name": "gate" } ],
          "components": [
            { "name": "Q1",   "data": "TAS/data/mosfets.ndjson?partNumber=C3M0032120K" },
            { "name": "C_in", "data": "TAS/data/capacitors.ndjson?partNumber=B32774" }
          ],
          "connections": [
            { "name": "dc_pos",   "endpoints": [ { "component": "Q1", "pin": "D" }, { "component": "C_in", "pin": "1" }, { "port": "dc+" } ] },
            { "name": "switched", "endpoints": [ { "component": "Q1", "pin": "S" }, { "port": "sw" } ] },
            { "name": "dc_neg",   "endpoints": [ { "component": "C_in", "pin": "2" }, { "port": "dc-" } ] },
            { "name": "gate",     "endpoints": [ { "component": "Q1", "pin": "G" }, { "port": "gate" } ] }
          ]
        },
        "inputPort":  { "port": "dc+", "type": "dcBus" },
        "outputPort": { "port": "sw",  "type": "hfAc" }
      },

      {
        "name": "transformer",
        "role": "isolation",
        "circuit": {
          "name": "flyback-transformer",
          "ports": [ { "name": "pri" }, { "name": "sec" }, { "name": "sec_rtn" } ],
          "components": [
            { "name": "T1", "data": "TAS/data/transformers.ndjson?partNumber=FLY-48-12-24W" }
          ],
          "connections": [
            { "name": "primary",   "endpoints": [ { "component": "T1", "pin": "P1" }, { "port": "pri" } ] },
            { "name": "secondary", "endpoints": [ { "component": "T1", "pin": "S1" }, { "port": "sec" } ] },
            { "name": "sec_return","endpoints": [ { "component": "T1", "pin": "S2" }, { "port": "sec_rtn" } ] }
          ]
        },
        "inputPort":   { "port": "pri", "type": "hfAc" },
        "outputPorts": [ { "port": "sec", "type": "hfAc" } ]
      },

      {
        "name": "rectifier",
        "role": "outputRectifier",
        "circuit": {
          "name": "single-diode-rectifier",
          "ports": [ { "name": "ac_in" }, { "name": "dc_out" } ],
          "components": [
            { "name": "D1", "data": "TAS/data/diodes.ndjson?partNumber=STPS20H100C" }
          ],
          "connections": [
            { "name": "anode",   "endpoints": [ { "component": "D1", "pin": "A" }, { "port": "ac_in" } ] },
            { "name": "cathode", "endpoints": [ { "component": "D1", "pin": "K" }, { "port": "dc_out" } ] }
          ]
        },
        "inputPort":  { "port": "ac_in",  "type": "hfAc" },
        "outputPort": { "port": "dc_out", "type": "pulsatingDc" }
      },

      {
        "name": "filter",
        "role": "outputFilter",
        "circuit": "TAS/data/circuits.ndjson?name=lc-output-filter",
        "inputPort":  { "port": "in",  "type": "pulsatingDc" },
        "outputPort": { "port": "out", "type": "dcOutput" }
      },

      {
        "name": "controller",
        "role": "control",
        "controlImplementation": "virtual",
        "senses": [
          { "net": "Vout", "signal": "voltage" }
        ],
        "drives": [
          { "stage": "inverter", "component": "Q1", "signal": "gate" }
        ]
      }
    ],

    "interStageConnections": [
      { "name": "Vin",  "kind": "externalPort", "direction": "input",
        "endpoints": [ { "stage": "inverter", "port": "dc+" } ] },
      { "name": "GND_in", "kind": "externalPort", "direction": "input",
        "endpoints": [ { "stage": "inverter", "port": "dc-" } ] },
      { "name": "Vout", "kind": "externalPort", "direction": "output",
        "endpoints": [ { "stage": "filter", "port": "out" } ] },
      { "name": "sw_node", "kind": "wire",
        "endpoints": [ { "stage": "inverter", "port": "sw" }, { "stage": "transformer", "port": "pri" } ] },
      { "name": "sec", "kind": "wire",
        "endpoints": [ { "stage": "transformer", "port": "sec" }, { "stage": "rectifier", "port": "ac_in" } ] },
      { "name": "rect_out", "kind": "wire",
        "endpoints": [ { "stage": "rectifier", "port": "dc_out" }, { "stage": "filter", "port": "in" } ] }
    ]
  },

  "simulation": {
    "analyses": [
      { "type": "transient", "stopTime": 0.002, "maximumTimeStep": 1e-7 }
    ],
    "stimulus": [
      { "stage": "inverter", "component": "Q1", "signal": "gate",
        "waveform": { "type": "pwm", "frequency": 100000, "dutyCycle": 0.4 } }
    ]
  }
}
