{
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "$id": "http://openconverters.com/schemas/TAS/utils.json",
    "title": "utils",
    "description": "Shared definition utilities for TAS (Topology Agnostic Structure)",
    "type": "object",
    "$defs": {
        "dimensionWithTolerance": {
            "description": "A dimension with minimum, nominal, and maximum values",
            "type": "object",
            "properties": {
                "minimum": {
                    "description": "The minimum value",
                    "type": "number"
                },
                "nominal": {
                    "description": "The nominal value",
                    "type": "number"
                },
                "maximum": {
                    "description": "The maximum value",
                    "type": "number"
                }
            },
            "anyOf": [
                {
                    "required": [
                        "minimum"
                    ]
                },
                {
                    "required": [
                        "nominal"
                    ]
                },
                {
                    "required": [
                        "maximum"
                    ]
                }
            ]
        },
        "curve": {
            "type": "object",
            "description": "X-Y curve data points",
            "additionalProperties": false,
            "properties": {
                "xData": {
                    "description": "X-axis values",
                    "$ref": "#/$defs/numberArray"
                },
                "yData": {
                    "description": "Y-axis values",
                    "$ref": "#/$defs/numberArray"
                }
            }
        },
        "numberArray": {
            "type": "array",
            "description": "Array of numeric values",
            "items": {
                "type": [
                    "number"
                ]
            }
        },
        "signalDescriptor": {
            "description": "Signal description in time domain (MAS-compatible). Must have waveform OR processed.",
            "type": "object",
            "properties": {
                "waveform": {
                    "description": "Time-domain waveform data (MAS-compatible)",
                    "type": "object",
                    "properties": {
                        "data": {
                            "$ref": "#/$defs/numberArray"
                        },
                        "time": {
                            "$ref": "#/$defs/numberArray"
                        },
                        "numberPeriods": {
                            "type": "integer",
                            "default": 1
                        }
                    },
                    "required": [
                        "data",
                        "time"
                    ]
                },
                "processed": {
                    "description": "Processed waveform parameters (MAS-compatible)",
                    "type": "object",
                    "properties": {
                        "label": {
                            "type": "string",
                            "enum": [
                                "Triangular",
                                "Sinusoidal",
                                "Rectangular",
                                "Custom",
                                "Unipolar Rectangular",
                                "Bipolar Rectangular",
                                "Flyback Primary",
                                "Flyback Secondary",
                                "Forward Primary",
                                "Forward Secondary"
                            ]
                        },
                        "dutyCycle": {
                            "type": "number",
                            "minimum": 0,
                            "maximum": 1
                        },
                        "peakToPeak": {
                            "type": "number"
                        },
                        "peak": {
                            "type": "number"
                        },
                        "offset": {
                            "type": "number"
                        },
                        "average": {
                            "type": "number"
                        },
                        "rms": {
                            "type": "number"
                        },
                        "effectiveFrequency": {
                            "type": "number"
                        }
                    }
                }
            },
            "anyOf": [
                {
                    "required": [
                        "waveform"
                    ]
                },
                {
                    "required": [
                        "processed"
                    ]
                }
            ]
        },
        "distributorInfo": {
            "description": "Where to buy this component.",
            "type": "object",
            "properties": {
                "name": {
                    "type": "string",
                    "description": "Distributor name (e.g. Digi-Key, Mouser)."
                },
                "reference": {
                    "type": [
                        "string",
                        "null"
                    ],
                    "description": "Distributor part number."
                },
                "link": {
                    "type": [
                        "string",
                        "null"
                    ],
                    "format": "uri",
                    "description": "Product page URL."
                },
                "cost": {
                    "type": [
                        "number",
                        "null"
                    ],
                    "description": "Unit cost in USD."
                },
                "stock": {
                    "type": [
                        "integer",
                        "null"
                    ],
                    "description": "Available stock quantity."
                },
                "country": {
                    "type": [
                        "string",
                        "null"
                    ],
                    "description": "Country of distribution."
                }
            },
            "required": [
                "name"
            ]
        },
        "substituteInfo": {
            "description": "A substitute or equivalent component that can replace this one.",
            "type": "object",
            "properties": {
                "partNumber": {
                    "type": "string",
                    "description": "Part number of the substitute."
                },
                "manufacturer": {
                    "type": [
                        "string",
                        "null"
                    ],
                    "description": "Manufacturer of the substitute."
                },
                "type": {
                    "type": "string",
                    "description": "Type of substitution.",
                    "enum": [
                        "drop-in",
                        "near-equivalent",
                        "functional",
                        "upgrade",
                        "downgrade",
                        "successor"
                    ]
                },
                "notes": {
                    "type": [
                        "string",
                        "null"
                    ],
                    "description": "Differences or caveats."
                },
                "source": {
                    "type": [
                        "string",
                        "null"
                    ],
                    "description": "Where this substitution was identified.",
                    "enum": [
                        "manufacturer",
                        "distributor",
                        "cross-reference",
                        "engineering",
                        null
                    ]
                }
            },
            "required": [
                "partNumber"
            ]
        },
        "datasheetInfoThermal": {
            "description": "Shared thermal section for datasheetInfo: operating temperature as dimensionWithTolerance (minimum = min operating, maximum = max operating).",
            "type": "object",
            "properties": {
                "operatingTemperature": {
                    "description": "Operating temperature range in degrees Celsius.",
                    "$ref": "#/$defs/dimensionWithTolerance"
                }
            }
        },
        "datasheetInfoMechanical": {
            "description": "Shared mechanical section for datasheetInfo: named dimensions as dimensionWithTolerance and connection type.",
            "type": "object",
            "properties": {
                "length": {
                    "description": "Body length in metres.",
                    "$ref": "#/$defs/dimensionWithTolerance"
                },
                "width": {
                    "description": "Body width in metres.",
                    "$ref": "#/$defs/dimensionWithTolerance"
                },
                "height": {
                    "description": "Body height in metres.",
                    "$ref": "#/$defs/dimensionWithTolerance"
                },
                "diameter": {
                    "description": "Body diameter in metres (for cylindrical parts).",
                    "$ref": "#/$defs/dimensionWithTolerance"
                },
                "assemblyType": {
                    "description": "PCB mounting / assembly type.",
                    "$ref": "#/$defs/connectionType"
                }
            }
        },
        "datasheetInfoBusiness": {
            "description": "Shared business / supply-chain section for datasheetInfo.",
            "type": "object",
            "properties": {
                "packaging": {
                    "type": [
                        "string",
                        "null"
                    ],
                    "description": "Packaging format (e.g. Tape & Reel, Bulk, Tray)."
                },
                "vpe": {
                    "type": [
                        "integer",
                        "null"
                    ],
                    "description": "Units per package / reel."
                },
                "moq": {
                    "type": [
                        "integer",
                        "null"
                    ],
                    "description": "Minimum order quantity."
                },
                "leadTime": {
                    "type": [
                        "number",
                        "null"
                    ],
                    "description": "Lead time in weeks."
                },
                "stock": {
                    "type": [
                        "integer",
                        "null"
                    ],
                    "description": "Available stock quantity."
                },
                "cost": {
                    "type": [
                        "number",
                        "null"
                    ],
                    "description": "Unit cost."
                }
            }
        },
        "manufacturerInfo": {
            "description": "Shared manufacturer information container. Each component type extends this via allOf to supply its own datasheetInfo schema.",
            "type": "object",
            "properties": {
                "name": {
                    "type": "string",
                    "description": "Manufacturer name"
                },
                "reference": {
                    "type": "string",
                    "description": "Manufacturer part number"
                },
                "status": {
                    "type": "string",
                    "enum": [
                        "production",
                        "nrnd",
                        "obsolete",
                        "preview"
                    ],
                    "description": "Production status"
                },
                "datasheetUrl": {
                    "type": "string",
                    "format": "uri",
                    "description": "URL to manufacturer datasheet"
                },
                "spiceModel": {
                    "type": "object",
                    "description": "SPICE simulation model for this component"
                }
            },
            "required": [
                "name"
            ]
        },
        "connectionType": {
            "description": "PCB / terminal connection type.",
            "type": "string",
            "enum": [
                "Pin",
                "Screw",
                "SMT",
                "Flying Lead",
                "THT",
                "Chassis"
            ]
        }
    }
}